{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Visual DNA Schema",
  "description": "VENHO AI Studio — Knowledge Studio v0.1",
  "type": "object",
  "required": ["meta", "dna", "rules"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["category", "version", "date", "image_count", "batch_count", "providers"],
      "properties": {
        "category": { "type": "string", "enum": ["Room", "Lobby", "Reception", "Facade", "Rooftop", "WestLake", "LinhAn", "Other"] },
        "version": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "image_count": { "type": "integer", "minimum": 1 },
        "batch_count": { "type": "integer", "minimum": 1 },
        "providers": {
          "type": "object",
          "properties": {
            "extraction": { "type": "string" },
            "merge": { "type": "string" }
          }
        }
      }
    },
    "dna": {
      "type": "object",
      "properties": {
        "visual":        { "$ref": "#/$defs/dna_section" },
        "material":      { "$ref": "#/$defs/dna_section" },
        "color":         { "$ref": "#/$defs/color_section" },
        "geometry":      { "$ref": "#/$defs/dna_section" },
        "lighting":      { "$ref": "#/$defs/dna_section" },
        "camera_angle":  { "$ref": "#/$defs/dna_section" }
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "fixed":              { "type": "array", "items": { "type": "string" } },
        "allowed_variations": { "type": "array", "items": { "type": "string" } },
        "negative":           { "type": "array", "items": { "type": "string" } }
      }
    },
    "synthesis_notes": { "type": "string" }
  },
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"]
    },
    "dna_section": {
      "type": "object",
      "properties": {
        "features": { "type": "array", "items": { "type": "string" } },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "color_section": {
      "type": "object",
      "properties": {
        "palette": { "type": "array", "items": { "type": "string" } },
        "dominant": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    }
  }
}
